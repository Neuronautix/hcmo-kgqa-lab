@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix hcmo: <http://w3id.org/hcmo#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

hcmo:HomeCageExperimentShape a sh:NodeShape ;
    sh:targetClass hcmo:HomeCageExperiment ;
    sh:property [
        sh:path hcmo:durationDays ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:minInclusive 1 ;
        sh:message "A HomeCageExperiment must have hcmo:durationDays (>= 1)." ;
    ] ;
    sh:property [
        sh:path hcmo:usesSystem ;
        sh:class hcmo:HomeCageSystem ;
        sh:minCount 1 ;
        sh:message "A HomeCageExperiment must use at least one hcmo:HomeCageSystem." ;
    ] ;
    sh:property [
        sh:path hcmo:hasCohort ;
        sh:class hcmo:AnimalCohort ;
        sh:minCount 1 ;
        sh:message "A HomeCageExperiment must study at least one hcmo:AnimalCohort." ;
    ] ;
    sh:property [
        sh:path hcmo:measuresMetric ;
        sh:class hcmo:BehavioralMetric ;
        sh:minCount 1 ;
        sh:message "A HomeCageExperiment must measure at least one hcmo:BehavioralMetric." ;
    ] .
