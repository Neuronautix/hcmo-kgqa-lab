# ---------------------------------------------------------------------------
# HCMO-KGQA Lab environment configuration
# Copy this file to `.env` and adjust values for your setup.
# ---------------------------------------------------------------------------

# --- Apache Jena / Fuseki (the single RDF graph backend) -------------------
FUSEKI_BASE_URL=http://localhost:3030
FUSEKI_DATASET=hcmo
FUSEKI_USER=admin
FUSEKI_PASSWORD=admin

# --- HCMO upstream sync layer ----------------------------------------------
# The lab vendors the canonical HCMO ontology/shapes/queries from the upstream
# repo into ontology/vendor/hcmo (and sibling vendor/ trees) via
# `make sync-hcmo`. The synthetic demo model stays the default.
HCMO_REPO_URL=https://github.com/dhuzard/HCMO
# Track `main` by default; pin to a tag or commit SHA for a reproducible build.
HCMO_REF=main
# Which ontology the lab treats as active:
#   synthetic = the bundled synthetic demo model (DEFAULT)
#   vendor    = the vendored real HCMO (set this AFTER running `make sync-hcmo`)
HCMO_ACTIVE_SOURCE=synthetic

# --- LLM provider ----------------------------------------------------------
# LLM_PROVIDER selects how natural-language steps (intent, SPARQL generation,
# grounded answers) are produced. Supported: openai | anthropic | ollama |
# mistral | gemini | custom
LLM_PROVIDER=openai

# LLM_MODEL: provider-specific model id (leave blank to use a provider default)
LLM_MODEL=

# LLM_API_KEY: API key for hosted providers (not needed for local Ollama)
LLM_API_KEY=

# LLM_BASE_URL: override the API base URL (OpenAI-compatible gateways, proxies)
LLM_BASE_URL=

# OLLAMA_BASE_URL: endpoint for a local Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Example provider presets (uncomment ONE block)
# ---------------------------------------------------------------------------

# --- OpenAI (hosted) -------------------------------------------------------
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# --- Anthropic (hosted) ----------------------------------------------------
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-latest
# LLM_API_KEY=sk-ant-...

# --- Ollama (local, no key required) ---------------------------------------
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# --- Mistral (hosted) ------------------------------------------------------
# LLM_PROVIDER=mistral
# LLM_MODEL=mistral-large-latest
# LLM_API_KEY=...

# --- Google Gemini (hosted) ------------------------------------------------
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-pro
# LLM_API_KEY=...
